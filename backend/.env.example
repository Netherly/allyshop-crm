# База данных
DATABASE_URL="postgresql://crm:crm@db:5432/allyshop?schema=public"
# для локального запуска без Docker: host db -> localhost

# Авторизация
JWT_SECRET="asdfhlksadjhfasoudfhasduhfw4fw9hfw98h"
JWT_EXPIRES_IN="7d"

# Первый супер-админ (создаётся сидом)
